# ===== BetV — Environment Variables =====
# Copy to .env and fill in your values.
# Without keys, the system runs in MOCK mode (fully functional with simulated data).

# --- Core ---
NODE_ENV=development
TZ=UTC
APP_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://betv:betv_secret@localhost:5432/betv?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
AUTH_SESSION_SECRET=change-me-to-a-random-64-char-string

# --- Football Data Provider ---
# Options: sportmonks | api-football | mock (default if empty)
DATA_PROVIDER=mock
SPORTMONKS_TOKEN=
APIFOOTBALL_KEY=

# --- AI (Anthropic/Claude) ---
# Leave empty for mock mode (pre-written analyses)
AI_API_KEY=
AI_MODEL_ANALYSIS=claude-opus-4-8
AI_MODEL_CHAT=claude-sonnet-4-6
# Embeddings: the RAG uses a LOCAL deterministic embedding in this phase — no key needed.
# A real embedding provider (e.g. Voyage) is roadmap; leave this empty for now.
AI_EMBEDDING_MODEL=

# --- AI fallback (OpenAI / ChatGPT) ---
# Resilience only: Anthropic stays primary; OpenAI is used when Anthropic fails.
# Leave OPENAI_API_KEY empty to disable the fallback (Anthropic-only, as today).
OPENAI_API_KEY=
OPENAI_MODEL_ANALYSIS=gpt-4o
OPENAI_MODEL_CHAT=gpt-4o-mini

# --- Email (Resend) ---
# Leave empty for mock mode (logs to console)
RESEND_API_KEY=
RESEND_FROM=BetV <noreply@betv.online>

# --- Payment (Mercado Pago) ---
# Leave empty for mock mode (simulated checkout). Fill all three to go real.
# Public Key is served to the browser at runtime via /api/mp/config (no NEXT_PUBLIC at build).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Só para DEMO em mock numa VPS de produção: libera o "simular aprovação" do checkout.
# Deixe vazio em produção real (com chaves do MP, é ignorado de qualquer forma).
ALLOW_MOCK_PAYMENTS=
